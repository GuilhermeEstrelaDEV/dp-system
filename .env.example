NODE_ENV=development
WEB_PORT=5173
API_PORT=3000
API_PREFIX=api
API_VERSION=1
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
POSTGRES_PORT=5432
POSTGRES_DB=dp_system
POSTGRES_USER=dp_system
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://dp_system:change-me@localhost:5432/dp_system?schema=public
REDIS_PORT=6379
JWT_SECRET=change-this-before-using-outside-local-development
JWT_EXPIRES_IN=15m
TRUST_PROXY=false
EMERGENCY_ACCESS_MAX_HOURS=8
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
HTTP_BODY_LIMIT=1mb
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=log
VITE_API_URL=http://localhost:3000/api
