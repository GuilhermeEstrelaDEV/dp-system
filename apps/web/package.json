    "@types/react-dom": "^19.0.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "^10.5.3",
    "postcss": "^8.4.49",
