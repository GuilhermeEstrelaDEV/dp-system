  @@map("leave_cases")
}

model LeaveCaseHistory {
  id          String    @id @default(uuid()) @db.Uuid
  leaveCaseId String    @map("leave_case_id") @db.Uuid
  action      String    @db.VarChar(30)
  reason      String?   @db.VarChar(1000)
  occurredAt  DateTime  @default(now()) @map("occurred_at") @db.Timestamptz(6)
  leaveCase   LeaveCase @relation(fields: [leaveCaseId], references: [id], onDelete: Restrict)

  @@index([leaveCaseId, occurredAt])
  @@map("leave_case_history")
}
