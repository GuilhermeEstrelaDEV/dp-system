generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum RefreshTokenStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum UserCompanyRoleStatus {
  ACTIVE
  INACTIVE
}

enum AccessGrantStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum PayrollReviewCycleStatus {
  OPEN
  IN_REVIEW
  SUBMITTED
  APPROVED
  REJECTED
  CLOSED
}

enum PayrollReviewFindingSeverity {
  INFORMATIONAL
  BLOCKING
}

enum PayrollReviewFindingStatus {
  OPEN
  RESOLVED
}

enum PayrollReviewEventType {
  REVIEW_CYCLE_OPENED
  FINDING_OPENED
  FINDING_RESOLVED
  FINDING_REOPENED
  REVIEW_STARTED
  REVIEW_SUBMITTED
  REVIEW_APPROVED
  REVIEW_REJECTED
  FINDING_BLOCKED
  FINDING_UNBLOCKED
  REVIEW_CLOSED
  REVIEW_REOPENED
  APPROVALS_INVALIDATED
}

enum PayrollReviewDecisionType {
  APPROVED
  REJECTED
}

enum PayrollPeriodClosureStatus {
  OPEN
  CLOSING
  CLOSED
  REOPENING
}

enum PayrollPeriodClosureEventType {
  PERIOD_READINESS_EVALUATED
  PERIOD_CLOSURE_STARTED
  PERIOD_CLOSED
  PERIOD_REOPENING_STARTED
  PERIOD_REOPENED
  CLOSURE_EVIDENCE_INVALIDATED
  VARIABLE_PAY_WARNING_ACKNOWLEDGED
}

enum PayrollPeriodClosureOperationType {
  CLOSE
  REOPEN
}

enum PayrollPeriodClosureIdempotencyStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

model User {
  id                                       String                                       @id @default(uuid()) @db.Uuid
  email                                    String                                       @unique @db.VarChar(254)
  displayName                              String                                       @map("display_name") @db.VarChar(160)
  passwordHash                             String?                                      @map("password_hash") @db.VarChar(255)
  status                                   UserStatus                                   @default(ACTIVE)
  mfaEnabled                               Boolean                                      @default(false) @map("mfa_enabled")
  createdAt                                DateTime                                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                DateTime                                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles                                    UserRole[]
  refreshTokens                            RefreshToken[]
  auditLogs                                AuditLog[]
  companyRoles                             UserCompanyRole[]
  substitutionsAsHolder                    TemporarySubstitution[]                      @relation("SubstitutionHolder")
  substitutionsAsSubstitute                TemporarySubstitution[]                      @relation("SubstitutionSubstitute")
  substitutionsGranted                     TemporarySubstitution[]                      @relation("SubstitutionGrantor")
  substitutionsRevoked                     TemporarySubstitution[]                      @relation("SubstitutionRevoker")
  emergencyAccesses                        EmergencyAccess[]                            @relation("EmergencyBeneficiary")
  emergencyAccessesGranted                 EmergencyAccess[]                            @relation("EmergencyGrantor")
  emergencyAccessesRevoked                 EmergencyAccess[]                            @relation("EmergencyRevoker")
  payrollReviewCyclesCreated               PayrollReviewCycle[]                         @relation("PayrollReviewCycleCreator")
  payrollReviewFindingsCreated             PayrollReviewFinding[]                       @relation("PayrollReviewFindingCreator")
  payrollReviewFindingsResolved            PayrollReviewFinding[]                       @relation("PayrollReviewFindingResolver")
  payrollReviewEvents                      PayrollReviewEvent[]                         @relation("PayrollReviewEventActor")
  payrollReviewDecisions                   PayrollReviewDecision[]                      @relation("PayrollReviewDecisionActor")
  payrollReviewInvalidations               PayrollReviewDecisionInvalidation[]          @relation("PayrollReviewInvalidationActor")
  payrollPeriodClosureVersionsCreated      PayrollPeriodClosureVersion[]                @relation("PayrollPeriodClosureVersionCreator")
  payrollPeriodClosureManifestsCreated     PayrollPeriodClosureManifest[]               @relation("PayrollPeriodClosureManifestCreator")
  payrollPeriodClosureEvents               PayrollPeriodClosureEvent[]                  @relation("PayrollPeriodClosureEventActor")
  payrollPeriodClosureWarningsAcknowledged PayrollPeriodClosureWarningAcknowledgement[] @relation("PayrollPeriodClosureWarningActor")

  @@map("users")
}

model Role {
  id           String            @id @default(uuid()) @db.Uuid
  code         String            @unique @db.VarChar(50)
  name         String            @db.VarChar(100)
  description  String?           @db.VarChar(255)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  users        UserRole[]
  permissions  RolePermission[]
  companyUsers UserCompanyRole[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(100)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserCompanyRole {
  id        String                @id @default(uuid()) @db.Uuid
  userId    String                @map("user_id") @db.Uuid
  companyId String                @map("company_id") @db.Uuid
  roleId    String                @map("role_id") @db.Uuid
  status    UserCompanyRoleStatus @default(ACTIVE)
  validFrom DateTime              @default(now()) @map("valid_from") @db.Timestamptz(6)
  validTo   DateTime?             @map("valid_to") @db.Timestamptz(6)
  createdAt DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  company   Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  role      Role                  @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([userId, companyId, status])
  @@index([companyId, roleId, status])
  @@map("user_company_roles")
}

model RefreshToken {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  tokenHash String             @unique @map("token_hash") @db.VarChar(255)
  status    RefreshTokenStatus @default(ACTIVE)
  expiresAt DateTime           @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime?          @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  actorUserId   String?  @map("actor_user_id") @db.Uuid
  companyId     String?  @map("company_id") @db.Uuid
  sessionId     String?  @map("session_id") @db.VarChar(100)
  entityType    String   @map("entity_type") @db.VarChar(100)
  entityId      String   @map("entity_id") @db.VarChar(100)
  action        String   @db.VarChar(50)
  traceId       String   @map("trace_id") @db.VarChar(100)
  metadata      Json?
  previousState Json?    @map("previous_state")
  nextState     Json?    @map("next_state")
  reason        String?  @db.VarChar(1000)
  ipAddress     String?  @map("ip_address") @db.VarChar(64)
  userAgent     String?  @map("user_agent") @db.VarChar(512)
  occurredAt    DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  actorUser     User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  company       Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId, occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([traceId])
  @@index([companyId, occurredAt])
  @@index([sessionId, occurredAt])
  @@map("audit_logs")
}

model Company {
  id                                          String                                       @id @default(uuid()) @db.Uuid
  legalName                                   String                                       @map("legal_name") @db.VarChar(160)
  tradeName                                   String                                       @map("trade_name") @db.VarChar(160)
  taxId                                       String                                       @unique @map("tax_id") @db.VarChar(20)
  status                                      String                                       @default("ACTIVE") @db.VarChar(20)
  createdAt                                   DateTime                                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                   DateTime                                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  branches                                    Branch[]
  departments                                 Department[]
  positions                                   Position[]
  costCenters                                 CostCenter[]
  employmentContracts                         EmploymentContract[]
  admissionProcesses                          AdmissionProcess[]
  checklistTemplates                          ChecklistTemplate[]
  workSchedules                               WorkSchedule[]
  holidays                                    Holiday[]
  timeEntries                                 TimeEntry[]
  timeBalanceClosings                         TimeBalanceClosing[]
  benefits                                    Benefit[]
  payrollPeriodClosureVersions                PayrollPeriodClosureVersion[]
  payrollPeriodClosureManifests               PayrollPeriodClosureManifest[]
  payrollPeriodClosureEvents                  PayrollPeriodClosureEvent[]
  payrollPeriodClosureWarningAcknowledgements PayrollPeriodClosureWarningAcknowledgement[]
  payrollPeriodClosureIdempotencies           PayrollPeriodClosureIdempotency[]
  collectiveVacations                         CollectiveVacation[]
  leaveTypes                                  LeaveType[]
  payrollCalendars                            PayrollCalendar[]
  payrollPeriods                              PayrollPeriod[]
  payrollRubricCategories                     PayrollRubricCategory[]
  payrollRubrics                              PayrollRubric[]
  payrollParameters                           PayrollParameter[]
  userRoles                                   UserCompanyRole[]
  auditLogs                                   AuditLog[]
  temporarySubstitutions                      TemporarySubstitution[]
  emergencyAccesses                           EmergencyAccess[]
  payrollReviewCycles                         PayrollReviewCycle[]
  payrollReviewFindings                       PayrollReviewFinding[]
  payrollReviewEvents                         PayrollReviewEvent[]
  payrollReviewDecisions                      PayrollReviewDecision[]
  payrollReviewInvalidations                  PayrollReviewDecisionInvalidation[]

  @@index([status])
  @@map("companies")
}

model TemporarySubstitution {
  id               String            @id @default(uuid()) @db.Uuid
  companyId        String            @map("company_id") @db.Uuid
  holderUserId     String            @map("holder_user_id") @db.Uuid
  substituteUserId String            @map("substitute_user_id") @db.Uuid
  grantedByUserId  String            @map("granted_by_user_id") @db.Uuid
  revokedByUserId  String?           @map("revoked_by_user_id") @db.Uuid
  capabilities     String[]
  startsAt         DateTime          @map("starts_at") @db.Timestamptz(6)
  expiresAt        DateTime          @map("expires_at") @db.Timestamptz(6)
  reason           String            @db.VarChar(1000)
  status           AccessGrantStatus @default(ACTIVE)
  revokedAt        DateTime?         @map("revoked_at") @db.Timestamptz(6)
  revocationReason String?           @map("revocation_reason") @db.VarChar(1000)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  holder           User              @relation("SubstitutionHolder", fields: [holderUserId], references: [id], onDelete: Restrict)
  substitute       User              @relation("SubstitutionSubstitute", fields: [substituteUserId], references: [id], onDelete: Restrict)
  grantedBy        User              @relation("SubstitutionGrantor", fields: [grantedByUserId], references: [id], onDelete: Restrict)
  revokedBy        User?             @relation("SubstitutionRevoker", fields: [revokedByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, substituteUserId, status, startsAt, expiresAt])
  @@index([companyId, holderUserId, status])
  @@map("temporary_substitutions")
}

model EmergencyAccess {
  id                String            @id @default(uuid()) @db.Uuid
  companyId         String            @map("company_id") @db.Uuid
  beneficiaryUserId String            @map("beneficiary_user_id") @db.Uuid
  grantedByUserId   String            @map("granted_by_user_id") @db.Uuid
  revokedByUserId   String?           @map("revoked_by_user_id") @db.Uuid
  capabilities      String[]
  startsAt          DateTime          @default(now()) @map("starts_at") @db.Timestamptz(6)
  expiresAt         DateTime          @map("expires_at") @db.Timestamptz(6)
  reason            String            @db.VarChar(1000)
  status            AccessGrantStatus @default(ACTIVE)
  revokedAt         DateTime?         @map("revoked_at") @db.Timestamptz(6)
  revocationReason  String?           @map("revocation_reason") @db.VarChar(1000)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  beneficiary       User              @relation("EmergencyBeneficiary", fields: [beneficiaryUserId], references: [id], onDelete: Restrict)
  grantedBy         User              @relation("EmergencyGrantor", fields: [grantedByUserId], references: [id], onDelete: Restrict)
  revokedBy         User?             @relation("EmergencyRevoker", fields: [revokedByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, beneficiaryUserId, status, startsAt, expiresAt])
  @@map("emergency_accesses")
}

model Branch {
  id                  String               @id @default(uuid()) @db.Uuid
  companyId           String               @map("company_id") @db.Uuid
  code                String               @db.VarChar(50)
  name                String               @db.VarChar(160)
  taxId               String?              @map("tax_id") @db.VarChar(20)
  address             Json?
  status              String               @default("ACTIVE") @db.VarChar(20)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  departments         Department[]
  employmentContracts EmploymentContract[]

  @@unique([companyId, code])
  @@unique([companyId, taxId])
  @@index([companyId, status])
  @@map("branches")
}

model Department {
  id                  String               @id @default(uuid()) @db.Uuid
  companyId           String               @map("company_id") @db.Uuid
  branchId            String?              @map("branch_id") @db.Uuid
  code                String               @db.VarChar(50)
  name                String               @db.VarChar(160)
  status              String               @default("ACTIVE") @db.VarChar(20)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  employmentContracts EmploymentContract[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([branchId])
  @@map("departments")
}

model Position {
  id                  String               @id @default(uuid()) @db.Uuid
  companyId           String               @map("company_id") @db.Uuid
  code                String               @db.VarChar(50)
  name                String               @db.VarChar(160)
  description         String?              @db.VarChar(1000)
  status              String               @default("ACTIVE") @db.VarChar(20)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employmentContracts EmploymentContract[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@map("positions")
}

model CostCenter {
  id                  String               @id @default(uuid()) @db.Uuid
  companyId           String               @map("company_id") @db.Uuid
  code                String               @db.VarChar(50)
  name                String               @db.VarChar(160)
  status              String               @default("ACTIVE") @db.VarChar(20)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employmentContracts EmploymentContract[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@map("cost_centers")
}

model Employee {
  id                  String               @id @default(uuid()) @db.Uuid
  legalName           String               @map("legal_name") @db.VarChar(160)
  preferredName       String?              @map("preferred_name") @db.VarChar(160)
  status              String               @default("ACTIVE") @db.VarChar(20)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  contacts            EmployeeContact[]
  employmentContracts EmploymentContract[]
  admissionProcesses  AdmissionProcess[]

  @@index([status])
  @@index([legalName])
  @@map("employees")
}

model EmployeeContact {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  type       String   @db.VarChar(20)
  value      String   @db.VarChar(254)
  isPrimary  Boolean  @default(false) @map("is_primary")
  status     String   @default("ACTIVE") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([employeeId, type, value])
  @@index([employeeId, status])
  @@map("employee_contacts")
}

model EmploymentContract {
  id                         String                      @id @default(uuid()) @db.Uuid
  employeeId                 String                      @map("employee_id") @db.Uuid
  companyId                  String                      @map("company_id") @db.Uuid
  branchId                   String?                     @map("branch_id") @db.Uuid
  departmentId               String?                     @map("department_id") @db.Uuid
  positionId                 String                      @map("position_id") @db.Uuid
  costCenterId               String?                     @map("cost_center_id") @db.Uuid
  registrationNumber         String                      @map("registration_number") @db.VarChar(50)
  contractType               String                      @map("contract_type") @db.VarChar(50)
  employmentRegime           String                      @map("employment_regime") @db.VarChar(50)
  startDate                  DateTime                    @map("start_date") @db.Date
  endDate                    DateTime?                   @map("end_date") @db.Date
  weeklyHours                Int                         @map("weekly_hours")
  status                     String                      @default("ACTIVE") @db.VarChar(20)
  createdAt                  DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  employee                   Employee                    @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  company                    Company                     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch                     Branch?                     @relation(fields: [branchId], references: [id], onDelete: Restrict)
  department                 Department?                 @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  position                   Position                    @relation(fields: [positionId], references: [id], onDelete: Restrict)
  costCenter                 CostCenter?                 @relation(fields: [costCenterId], references: [id], onDelete: Restrict)
  history                    ContractHistory[]
  admissionProcesses         AdmissionProcess[]
  workScheduleAssignments    ContractWorkSchedule[]
  timeEntries                TimeEntry[]
  timeBalanceEntries         TimeBalanceEntry[]
  benefitEnrollments         BenefitEnrollment[]
  vacationPeriods            VacationPeriod[]
  vacationRequests           VacationRequest[]
  leaveCases                 LeaveCase[]
  payrollInputs              PayrollInput[]
  payrollRunEmployees        PayrollRunEmployee[]
  variableCompensationEvents VariableCompensationEvent[]
  salaryAdvances             SalaryAdvance[]
  offCyclePayments           OffCyclePayment[]
  payrollReviewFindings      PayrollReviewFinding[]

  @@unique([companyId, registrationNumber])
  @@index([employeeId, status])
  @@index([companyId, status])
  @@map("employment_contracts")
}

model ContractHistory {
  id                   String             @id @default(uuid()) @db.Uuid
  employmentContractId String             @map("employment_contract_id") @db.Uuid
  action               String             @db.VarChar(50)
  reason               String?            @db.VarChar(500)
  snapshot             Json?
  occurredAt           DateTime           @default(now()) @map("occurred_at") @db.Timestamptz(6)
  employmentContract   EmploymentContract @relation(fields: [employmentContractId], references: [id], onDelete: Restrict)

  @@index([employmentContractId, occurredAt])
  @@map("contract_history")
}

model AdmissionProcess {
  id                     String                         @id @default(uuid()) @db.Uuid
  employeeId             String                         @map("employee_id") @db.Uuid
  employmentContractId   String                         @map("employment_contract_id") @db.Uuid
  companyId              String                         @map("company_id") @db.Uuid
  checklistTemplateId    String?                        @map("checklist_template_id") @db.Uuid
  plannedAdmissionDate   DateTime                       @map("planned_admission_date") @db.Date
  effectiveAdmissionDate DateTime?                      @map("effective_admission_date") @db.Date
  status                 String                         @default("DRAFT") @db.VarChar(20)
  operationalOwner       String?                        @map("operational_owner") @db.VarChar(160)
  notes                  String?                        @db.VarChar(2000)
  cancellationReason     String?                        @map("cancellation_reason") @db.VarChar(500)
  completedAt            DateTime?                      @map("completed_at") @db.Timestamptz(6)
  cancelledAt            DateTime?                      @map("cancelled_at") @db.Timestamptz(6)
  createdAt              DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  employee               Employee                       @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  employmentContract     EmploymentContract             @relation(fields: [employmentContractId], references: [id], onDelete: Restrict)
  company                Company                        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  checklistTemplate      ChecklistTemplate?             @relation(fields: [checklistTemplateId], references: [id], onDelete: Restrict)
  checklistInstances     ChecklistInstance[]
  documents              AdmissionDocumentRequirement[]
  statusHistory          AdmissionStatusHistory[]

  @@index([employmentContractId, status])
  @@index([companyId, status])
  @@index([plannedAdmissionDate])
  @@map("admission_processes")
}

model ChecklistTemplate {
  id                 String                  @id @default(uuid()) @db.Uuid
  companyId          String                  @map("company_id") @db.Uuid
  name               String                  @db.VarChar(160)
  description        String?                 @db.VarChar(1000)
  status             String                  @default("ACTIVE") @db.VarChar(20)
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  company            Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  items              ChecklistTemplateItem[]
  admissionProcesses AdmissionProcess[]

  @@unique([companyId, name])
  @@index([companyId, status])
  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id                  String            @id @default(uuid()) @db.Uuid
  checklistTemplateId String            @map("checklist_template_id") @db.Uuid
  title               String            @db.VarChar(160)
  description         String?           @db.VarChar(1000)
  sortOrder           Int               @map("sort_order")
  isRequired          Boolean           @default(true) @map("is_required")
  relativeDueDays     Int?              @map("relative_due_days")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  checklistTemplate   ChecklistTemplate @relation(fields: [checklistTemplateId], references: [id], onDelete: Restrict)

  @@unique([checklistTemplateId, sortOrder])
