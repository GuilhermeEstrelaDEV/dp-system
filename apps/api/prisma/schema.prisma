generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum RefreshTokenStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model User {
  id           String         @id @default(uuid()) @db.Uuid
  email        String         @unique @db.VarChar(254)
  displayName  String         @map("display_name") @db.VarChar(160)
  passwordHash String?        @map("password_hash") @db.VarChar(255)
  status       UserStatus     @default(ACTIVE)
  mfaEnabled   Boolean        @default(false) @map("mfa_enabled")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles        UserRole[]
  refreshTokens RefreshToken[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(50)
  name        String           @db.VarChar(100)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(100)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  tokenHash String             @unique @map("token_hash") @db.VarChar(255)
  status    RefreshTokenStatus @default(ACTIVE)
  expiresAt DateTime           @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime?          @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  entityType  String   @map("entity_type") @db.VarChar(100)
  entityId    String   @map("entity_id") @db.VarChar(100)
  action      String   @db.VarChar(50)
  traceId     String   @map("trace_id") @db.VarChar(100)
  metadata    Json?
  occurredAt  DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([traceId])
  @@map("audit_logs")
}

model Company {
  id          String       @id @default(uuid()) @db.Uuid
  legalName   String       @map("legal_name") @db.VarChar(160)
  tradeName   String       @map("trade_name") @db.VarChar(160)
  taxId       String       @unique @map("tax_id") @db.VarChar(20)
  status      String       @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  branches    Branch[]
  departments Department[]
  positions   Position[]
  costCenters CostCenter[]
  employmentContracts EmploymentContract[]
  admissionProcesses AdmissionProcess[]
  checklistTemplates ChecklistTemplate[]
  workSchedules WorkSchedule[]
  holidays Holiday[]
  timeEntries TimeEntry[]
  timeBalanceClosings TimeBalanceClosing[]
  benefits Benefit[]
  collectiveVacations CollectiveVacation[]
  leaveTypes LeaveType[]

  @@index([status])
  @@map("companies")
}

model Branch {
  id          String       @id @default(uuid()) @db.Uuid
  companyId   String       @map("company_id") @db.Uuid
  code        String       @db.VarChar(50)
  name        String       @db.VarChar(160)
  taxId       String?      @map("tax_id") @db.VarChar(20)
  address     Json?
  status      String       @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  departments Department[]
  employmentContracts EmploymentContract[]

  @@unique([companyId, code])
  @@unique([companyId, taxId])
  @@index([companyId, status])
  @@map("branches")
}

model Department {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  code      String    @db.VarChar(50)
  name      String    @db.VarChar(160)
  status    String    @default("ACTIVE") @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch    Branch?   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  employmentContracts EmploymentContract[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([branchId])
  @@map("departments")
}

model Position {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  code        String   @db.VarChar(50)
  name        String   @db.VarChar(160)
  description String?  @db.VarChar(1000)
  status      String   @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employmentContracts EmploymentContract[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@map("positions")
}

model CostCenter {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  code      String   @db.VarChar(50)
  name      String   @db.VarChar(160)
  status    String   @default("ACTIVE") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employmentContracts EmploymentContract[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@map("cost_centers")
}

model Employee {
  id                  String              @id @default(uuid()) @db.Uuid
  legalName           String              @map("legal_name") @db.VarChar(160)
  preferredName       String?             @map("preferred_name") @db.VarChar(160)
  status              String              @default("ACTIVE") @db.VarChar(20)
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  contacts            EmployeeContact[]
  employmentContracts EmploymentContract[]
  admissionProcesses AdmissionProcess[]

  @@index([status])
  @@index([legalName])
  @@map("employees")
}

model EmployeeContact {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  type       String   @db.VarChar(20)
  value      String   @db.VarChar(254)
  isPrimary  Boolean  @default(false) @map("is_primary")
  status     String   @default("ACTIVE") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([employeeId, type, value])
  @@index([employeeId, status])
  @@map("employee_contacts")
}

model EmploymentContract {
  id                 String             @id @default(uuid()) @db.Uuid
  employeeId         String             @map("employee_id") @db.Uuid
  companyId          String             @map("company_id") @db.Uuid
  branchId           String?            @map("branch_id") @db.Uuid
  departmentId       String?            @map("department_id") @db.Uuid
  positionId         String             @map("position_id") @db.Uuid
  costCenterId       String?            @map("cost_center_id") @db.Uuid
  registrationNumber String             @map("registration_number") @db.VarChar(50)
  contractType       String             @map("contract_type") @db.VarChar(50)
  employmentRegime   String             @map("employment_regime") @db.VarChar(50)
  startDate          DateTime           @map("start_date") @db.Date
  endDate            DateTime?          @map("end_date") @db.Date
  weeklyHours        Int                @map("weekly_hours")
  status             String             @default("ACTIVE") @db.VarChar(20)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  employee           Employee           @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch             Branch?            @relation(fields: [branchId], references: [id], onDelete: Restrict)
  department         Department?        @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  position           Position           @relation(fields: [positionId], references: [id], onDelete: Restrict)
  costCenter         CostCenter?        @relation(fields: [costCenterId], references: [id], onDelete: Restrict)
  history            ContractHistory[]
  admissionProcesses AdmissionProcess[]
  workScheduleAssignments ContractWorkSchedule[]
  timeEntries TimeEntry[]
  timeBalanceEntries TimeBalanceEntry[]
  benefitEnrollments BenefitEnrollment[]
  vacationPeriods VacationPeriod[]
  vacationRequests VacationRequest[]
  leaveCases LeaveCase[]

  @@unique([companyId, registrationNumber])
  @@index([employeeId, status])
  @@index([companyId, status])
  @@map("employment_contracts")
}

model ContractHistory {
  id                   String             @id @default(uuid()) @db.Uuid
  employmentContractId String             @map("employment_contract_id") @db.Uuid
  action               String             @db.VarChar(50)
  reason               String?            @db.VarChar(500)
  snapshot             Json?
  occurredAt           DateTime           @default(now()) @map("occurred_at") @db.Timestamptz(6)
  employmentContract   EmploymentContract @relation(fields: [employmentContractId], references: [id], onDelete: Restrict)

  @@index([employmentContractId, occurredAt])
  @@map("contract_history")
}

model AdmissionProcess {
  id                    String                         @id @default(uuid()) @db.Uuid
  employeeId            String                         @map("employee_id") @db.Uuid
  employmentContractId  String                         @map("employment_contract_id") @db.Uuid
  companyId             String                         @map("company_id") @db.Uuid
  checklistTemplateId   String?                        @map("checklist_template_id") @db.Uuid
  plannedAdmissionDate  DateTime                       @map("planned_admission_date") @db.Date
  effectiveAdmissionDate DateTime?                     @map("effective_admission_date") @db.Date
  status                String                         @default("DRAFT") @db.VarChar(20)
  operationalOwner      String?                        @map("operational_owner") @db.VarChar(160)
  notes                 String?                        @db.VarChar(2000)
  cancellationReason    String?                        @map("cancellation_reason") @db.VarChar(500)
  completedAt           DateTime?                      @map("completed_at") @db.Timestamptz(6)
  cancelledAt           DateTime?                      @map("cancelled_at") @db.Timestamptz(6)
  createdAt             DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  employee              Employee                       @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  employmentContract    EmploymentContract             @relation(fields: [employmentContractId], references: [id], onDelete: Restrict)
  company               Company                        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  checklistTemplate     ChecklistTemplate?             @relation(fields: [checklistTemplateId], references: [id], onDelete: Restrict)
  checklistInstances    ChecklistInstance[]
  documents             AdmissionDocumentRequirement[]
  statusHistory         AdmissionStatusHistory[]

  @@index([employmentContractId, status])
  @@index([companyId, status])
  @@index([plannedAdmissionDate])
  @@map("admission_processes")
}

model ChecklistTemplate {
  id        String                      @id @default(uuid()) @db.Uuid
  companyId String                      @map("company_id") @db.Uuid
  name      String                      @db.VarChar(160)
  description String?                   @db.VarChar(1000)
  status    String                      @default("ACTIVE") @db.VarChar(20)
  createdAt DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  company   Company                     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  items     ChecklistTemplateItem[]
  admissionProcesses AdmissionProcess[]

  @@unique([companyId, name])
  @@index([companyId, status])
  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id              String            @id @default(uuid()) @db.Uuid
  checklistTemplateId String         @map("checklist_template_id") @db.Uuid
  title           String             @db.VarChar(160)
  description     String?            @db.VarChar(1000)
  sortOrder       Int                @map("sort_order")
  isRequired      Boolean            @default(true) @map("is_required")
  relativeDueDays Int?               @map("relative_due_days")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  checklistTemplate ChecklistTemplate @relation(fields: [checklistTemplateId], references: [id], onDelete: Restrict)

  @@unique([checklistTemplateId, sortOrder])
  @@map("checklist_template_items")
}

model ChecklistInstance {
  id               String              @id @default(uuid()) @db.Uuid
  admissionProcessId String             @map("admission_process_id") @db.Uuid
  checklistTemplateId String?           @map("checklist_template_id") @db.Uuid
  templateName      String?             @map("template_name") @db.VarChar(160)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  admissionProcess  AdmissionProcess    @relation(fields: [admissionProcessId], references: [id], onDelete: Restrict)
  items             AdmissionChecklistItem[]

  @@unique([admissionProcessId])
  @@map("checklist_instances")
}

model AdmissionChecklistItem {
  id                 String              @id @default(uuid()) @db.Uuid
  checklistInstanceId String              @map("checklist_instance_id") @db.Uuid
  title              String               @db.VarChar(160)
  description        String?              @db.VarChar(1000)
  sortOrder          Int                  @map("sort_order")
  isRequired         Boolean              @default(true) @map("is_required")
  dueDate            DateTime?            @map("due_date") @db.Date
  status             String               @default("PENDING") @db.VarChar(20)
  observation        String?              @db.VarChar(1000)
  completedAt        DateTime?            @map("completed_at") @db.Timestamptz(6)
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  checklistInstance  ChecklistInstance    @relation(fields: [checklistInstanceId], references: [id], onDelete: Restrict)
  history            AdmissionChecklistItemHistory[]

  @@unique([checklistInstanceId, sortOrder])
  @@index([status, dueDate])
  @@map("admission_checklist_items")
}

model AdmissionChecklistItemHistory {
  id                      String                 @id @default(uuid()) @db.Uuid
  admissionChecklistItemId String                 @map("admission_checklist_item_id") @db.Uuid
  action                  String                  @db.VarChar(50)
  reason                  String?                 @db.VarChar(1000)
  occurredAt              DateTime                @default(now()) @map("occurred_at") @db.Timestamptz(6)
  admissionChecklistItem  AdmissionChecklistItem  @relation(fields: [admissionChecklistItemId], references: [id], onDelete: Restrict)

  @@index([admissionChecklistItemId, occurredAt])
  @@map("admission_checklist_item_history")
}

model AdmissionDocumentRequirement {
  id                 String           @id @default(uuid()) @db.Uuid
  admissionProcessId String           @map("admission_process_id") @db.Uuid
  documentType       String           @map("document_type") @db.VarChar(160)
  isRequired         Boolean          @default(true) @map("is_required")
  receiptStatus      String           @default("PENDING") @map("receipt_status") @db.VarChar(20)
  reviewStatus       String           @default("PENDING") @map("review_status") @db.VarChar(20)
  receivedAt         DateTime?        @map("received_at") @db.Timestamptz(6)
  reviewedAt         DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  observation        String?          @db.VarChar(1000)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  admissionProcess   AdmissionProcess @relation(fields: [admissionProcessId], references: [id], onDelete: Restrict)

  @@index([admissionProcessId, receiptStatus])
  @@map("admission_document_requirements")
}

model AdmissionStatusHistory {
  id                 String           @id @default(uuid()) @db.Uuid
  admissionProcessId String           @map("admission_process_id") @db.Uuid
  status             String           @db.VarChar(20)
  reason             String?          @db.VarChar(1000)
  occurredAt         DateTime         @default(now()) @map("occurred_at") @db.Timestamptz(6)
  admissionProcess   AdmissionProcess @relation(fields: [admissionProcessId], references: [id], onDelete: Restrict)

  @@index([admissionProcessId, occurredAt])
  @@map("admission_status_history")
}

model WorkSchedule {
  id String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  code String @db.VarChar(50)
  name String @db.VarChar(160)
  weeklyMinutes Int @map("weekly_minutes")
  status String @default("ACTIVE") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  periods WorkSchedulePeriod[]
  assignments ContractWorkSchedule[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@map("work_schedules")
}

model WorkSchedulePeriod {
  id String @id @default(uuid()) @db.Uuid
  workScheduleId String @map("work_schedule_id") @db.Uuid
  weekday Int
  startMinute Int @map("start_minute")
  endMinute Int @map("end_minute")
  breakMinutes Int @default(0) @map("break_minutes")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  workSchedule WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Restrict)

  @@unique([workScheduleId, weekday, startMinute])
  @@map("work_schedule_periods")
}

model ContractWorkSchedule {
  id String @id @default(uuid()) @db.Uuid
  employmentContractId String @map("employment_contract_id") @db.Uuid
  workScheduleId String @map("work_schedule_id") @db.Uuid
  validFrom DateTime @map("valid_from") @db.Date
  validTo DateTime? @map("valid_to") @db.Date
  reason String? @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  employmentContract EmploymentContract @relation(fields: [employmentContractId], references: [id], onDelete: Restrict)
  workSchedule WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Restrict)

  @@unique([employmentContractId, validFrom])
  @@index([workScheduleId])
  @@map("contract_work_schedules")
}

model Holiday {
  id String @id @default(uuid()) @db.Uuid
  companyId String? @map("company_id") @db.Uuid
  holidayDate DateTime @map("holiday_date") @db.Date
  name String @db.VarChar(160)
  scope String @default("COMPANY") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, holidayDate, name])
  @@index([holidayDate])
  @@map("holidays")
}

model TimeEntry {
  id String @id @default(uuid()) @db.Uuid
  employmentContractId String @map("employment_contract_id") @db.Uuid
  companyId String @map("company_id") @db.Uuid
  occurredOn DateTime @map("occurred_on") @db.Date
  type String @db.VarChar(30)
  minutes Int
  source String @default("MANUAL") @db.VarChar(30)
  status String @default("PENDING") @db.VarChar(20)
  reason String? @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  employmentContract EmploymentContract @relation(fields: [employmentContractId], references: [id], onDelete: Restrict)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  balanceEntries TimeBalanceEntry[]

  @@index([employmentContractId, occurredOn])
  @@index([companyId, occurredOn])
  @@map("time_entries")
}

model TimeBalanceEntry {
  id String @id @default(uuid()) @db.Uuid
  employmentContractId String @map("employment_contract_id") @db.Uuid
  timeEntryId String? @map("time_entry_id") @db.Uuid
  occurredOn DateTime @map("occurred_on") @db.Date
  minutes Int
  type String @db.VarChar(30)
  reason String? @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  employmentContract EmploymentContract @relation(fields: [employmentContractId], references: [id], onDelete: Restrict)
  timeEntry TimeEntry? @relation(fields: [timeEntryId], references: [id], onDelete: Restrict)

  @@index([employmentContractId, occurredOn])
  @@map("time_balance_entries")
}

model TimeBalanceClosing {
  id String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  referenceMonth DateTime @map("reference_month") @db.Date
  status String @default("OPEN") @db.VarChar(20)
  closedAt DateTime? @map("closed_at") @db.Timestamptz(6)
  reason String? @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, referenceMonth])
  @@map("time_balance_closings")
}

model Benefit {
  id String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  code String @db.VarChar(50)
  name String @db.VarChar(160)
  type String @db.VarChar(30)
  status String @default("ACTIVE") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  plans BenefitPlan[]
  @@unique([companyId, code])
  @@map("benefits")
}

